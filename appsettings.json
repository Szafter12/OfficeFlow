{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Mvc": "Error",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { 
        "Name": "File", 
        "Args": { 
          "path": "logs/log-.txt", 
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        } 
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost; Port=5432; Database=OfficeFlow; Username=postgres; Password=zaq1@WSX"
  },
  "AllowedHosts": "*"
}
